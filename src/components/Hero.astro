---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const basePath = lang === 'ar' ? '/ar' : '';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Grid background -->
  <div class="absolute inset-0 hero-bg" aria-hidden="true"></div>

  <!-- Animated gradient orbs -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div
      class="absolute -top-40 -left-40 h-96 w-96 rounded-full bg-primary/8 blur-3xl float"
      style="animation-delay: 0s;"
    ></div>
    <div
      class="absolute top-1/3 -right-32 h-80 w-80 rounded-full bg-violet/6 blur-3xl float"
      style="animation-delay: 2s;"
    ></div>
    <div
      class="absolute -bottom-20 left-1/3 h-72 w-72 rounded-full bg-primary/5 blur-3xl float"
      style="animation-delay: 4s;"
    ></div>
  </div>

  <!-- Fade out at bottom -->
  <div
    class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-background to-transparent"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center py-28 sm:py-36">

    <!-- Badge -->
    <div class="reveal mb-8 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary backdrop-blur-sm">
      <span class="h-1.5 w-1.5 rounded-full bg-primary pulse-dot"></span>
      {t('hero.badge')}
    </div>

    <!-- Headline -->
    <h1 class="reveal delay-100 text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.08] mb-6">
      <span class="block text-foreground">{t('hero.headline1')}</span>
      <span class="block text-foreground">{t('hero.headline2')}</span>
      <span class="block gradient-text">{t('hero.headline3')}</span>
    </h1>

    <!-- Subtext -->
    <p class="reveal delay-200 mx-auto max-w-2xl text-lg sm:text-xl text-muted-foreground leading-relaxed mb-10">
      {t('hero.subtext')}
    </p>

    <!-- CTAs -->
    <div class="reveal delay-300 flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="#"
        class="group inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-7 py-3.5 text-base font-semibold text-white glow-btn"
      >
        {t('hero.cta.primary')}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
          class="transition-transform duration-200 group-hover:translate-x-1 rtl:rotate-180 rtl:group-hover:-translate-x-1 rtl:group-hover:translate-x-0"
        >
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
      <a
        href={`${basePath}/#how-it-works`}
        class="inline-flex items-center justify-center gap-2 rounded-xl border border-card-border px-7 py-3.5 text-base font-semibold text-foreground hover:bg-card hover:border-primary/40 hover:-translate-y-0.5 transition-all duration-200"
      >
        {t('hero.cta.secondary')}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </a>
    </div>

    <!-- Stats -->
    <div class="reveal delay-500 mt-20 grid grid-cols-3 gap-4 max-w-md mx-auto">
      <div class="text-center">
        <div
          class="stat-number text-3xl sm:text-4xl font-bold text-foreground"
          data-count="1200"
          data-suffix="+"
        >0</div>
        <div class="text-xs sm:text-sm text-muted-foreground mt-1.5">{t('hero.stats.channels')}</div>
      </div>
      <div class="text-center relative before:absolute before:inset-y-0 before:left-0 before:w-px before:bg-card-border after:absolute after:inset-y-0 after:right-0 after:w-px after:bg-card-border">
        <div
          class="stat-number text-3xl sm:text-4xl font-bold text-foreground"
          data-count="50"
          data-prefix="$"
          data-suffix="K+"
        >$0</div>
        <div class="text-xs sm:text-sm text-muted-foreground mt-1.5">{t('hero.stats.paid')}</div>
      </div>
      <div class="text-center">
        <div
          class="stat-number text-3xl sm:text-4xl font-bold text-foreground"
          data-count="99.9"
          data-suffix="%"
        >0</div>
        <div class="text-xs sm:text-sm text-muted-foreground mt-1.5">{t('hero.stats.uptime')}</div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="reveal delay-600 mt-16 flex justify-center">
      <a
        href={`${basePath}/#features`}
        class="flex flex-col items-center gap-2 text-xs text-muted-foreground hover:text-foreground transition-colors group"
        aria-label="Scroll down"
      >
        <div class="flex h-8 w-5 items-start justify-center rounded-full border border-card-border p-1 group-hover:border-primary/40 transition-colors">
          <div class="h-1.5 w-0.5 rounded-full bg-muted-foreground animate-bounce"></div>
        </div>
      </a>
    </div>
  </div>
</section>
