---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const features = [
  {
    title: t('features.bot.title'),
    desc: t('features.bot.desc'),
    delay: '',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
      <rect width="18" height="12" x="3" y="8" rx="2"/><path d="M7 8V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/><circle cx="9" cy="13" r="1" fill="currentColor"/><circle cx="15" cy="13" r="1" fill="currentColor"/><path d="M9.5 17h5"/>
    </svg>`,
  },
  {
    title: t('features.crypto.title'),
    desc: t('features.crypto.desc'),
    delay: 'delay-100',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10"/><path d="M9.5 9H14a2 2 0 0 1 0 4H9.5"/><path d="M9.5 13H14a2 2 0 0 1 0 4H9.5"/><path d="M9.5 7v11"/><path d="M11.5 7v1"/><path d="M11.5 17v1"/>
    </svg>`,
  },
  {
    title: t('features.notifications.title'),
    desc: t('features.notifications.desc'),
    delay: 'delay-200',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/><circle cx="19" cy="5" r="3" fill="#6366f1" stroke="none"/>
    </svg>`,
  },
  {
    title: t('features.plans.title'),
    desc: t('features.plans.desc'),
    delay: 'delay-300',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
      <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><path d="M3 17h4"/><path d="M5 15v4"/>
    </svg>`,
  },
  {
    title: t('features.dashboard.title'),
    desc: t('features.dashboard.desc'),
    delay: 'delay-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
      <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
    </svg>`,
  },
  {
    title: t('features.instant.title'),
    desc: t('features.instant.desc'),
    delay: 'delay-500',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
      <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
    </svg>`,
  },
];
---

<section id="features" class="relative py-24 sm:py-32 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-primary/4 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20">
      <div class="reveal inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-primary mb-4">
        <span class="h-1 w-1 rounded-full bg-primary"></span>
        {t('features.badge')}
      </div>
      <h2 class="reveal delay-100 text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground tracking-tight mb-4">
        {t('features.headline')}
      </h2>
      <p class="reveal delay-200 mx-auto max-w-2xl text-lg text-muted-foreground leading-relaxed">
        {t('features.subtext')}
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature) => (
        <div class={`reveal ${feature.delay} group relative rounded-xl border border-card-border bg-card p-6 feature-card shimmer overflow-hidden`}>
          <!-- Icon -->
          <div class="feature-icon-wrap mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <Fragment set:html={feature.icon} />
          </div>

          <!-- Title -->
          <h3 class="mb-2 text-base font-semibold text-foreground">
            {feature.title}
          </h3>

          <!-- Desc -->
          <p class="text-sm text-muted-foreground leading-relaxed">
            {feature.desc}
          </p>

          <!-- Subtle corner accent -->
          <div class="absolute top-0 right-0 h-16 w-16 bg-gradient-to-bl from-primary/6 to-transparent rounded-bl-3xl pointer-events-none"></div>
        </div>
      ))}
    </div>
  </div>
</section>
